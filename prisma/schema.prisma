generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  description String
  category    String
  unitPrice   Decimal
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sales SaleDetail[]
}

model Sale {
  id          Int          @id @default(autoincrement())

  createdAt   DateTime     @default(now())

  latitude    Decimal?

  longitude   Decimal?

  total       Decimal

  details     SaleDetail[]
}

model SaleDetail {
  id          Int      @id @default(autoincrement())

  saleId      Int
  articleId   Int

  quantity    Int

  unitPrice   Decimal

  subtotal    Decimal

  sale        Sale     @relation(fields: [saleId], references: [id])

  article     Article  @relation(fields: [articleId], references: [id])
}